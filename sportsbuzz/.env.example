# Copy to .env and fill in. Used by backend_client + social fetchers.

# sports-data-backend base URL (no trailing slash)
SPORTS_BACKEND_URL=http://localhost:3000

# Optional label for ingested social rows (stored as `source` in the API)
# SOCIAL_INGEST_SOURCE=social_pipeline

# --- Twitter / X API v2 (Bearer token) ---
# TWITTER_BEARER_TOKEN=

# --- YouTube Data API v3 ---
# YOUTUBE_API_KEY=

# --- Instagram Graph API (long-lived token) ---
# INSTAGRAM_ACCESS_TOKEN=
