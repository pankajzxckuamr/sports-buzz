NODE_ENV=development
PORT=3000
LOG_LEVEL=info

DATABASE_URL=postgresql://sports:sports@localhost:5432/sports_data
REDIS_URL=redis://localhost:6379

# Raw artifacts (local filesystem; swap for S3-compatible SDK in production)
RAW_STORAGE_ROOT=./data/raw

# OpenAI (optional — without key, enrichment uses rule-based fallbacks)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Elasticsearch (optional — leave empty to disable)
ELASTICSEARCH_URL=http://localhost:9200
